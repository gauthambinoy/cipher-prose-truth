# ClarityAI Backend Configuration
# Copy to .env for local development. Use provider secret managers in production.

# General
APP_NAME=ClarityAI
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered content analysis, plagiarism detection and humanization
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-32-byte-string

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database
DATABASE_URL=sqlite+aiosqlite:///./clarityai.db
DB_ECHO=false

# CORS (comma-separated origins; add your deployed Vercel URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://clarityai-pied.vercel.app
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_BURST=5

# Detection limits
MIN_WORDS=50
MAX_WORDS=10000
FAST_MODE_SIGNALS=3
DEEP_MODE_SIGNALS=14
AI_THRESHOLD_HIGH=0.85
AI_THRESHOLD_MEDIUM=0.50

# Ollama (optional local LLM for humanization)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT=120
HUMANIZE_TARGET_AI_SCORE=0.10
HUMANIZE_TARGET_PLAG_SCORE=0.10
HUMANIZE_MAX_ITERATIONS=5
HUMANIZE_TEMPERATURE=0.7

# Batch / uploads
BATCH_MAX_FILES=50
BATCH_MAX_FILE_SIZE_MB=10
