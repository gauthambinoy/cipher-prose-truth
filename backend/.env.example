# ClarityAI Backend Configuration
# Copy this to .env and adjust values

# General
APP_NAME=ClarityAI
DEBUG=false
SECRET_KEY=change-me-to-a-random-string

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./clarityai.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Ollama (local LLM for humanization)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT=120

# Rate Limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=3600

# Detection
MIN_WORDS=50
MAX_WORDS=10000

# Humanization
HUMANIZE_TARGET_AI_SCORE=0.10
HUMANIZE_MAX_ITERATIONS=5
